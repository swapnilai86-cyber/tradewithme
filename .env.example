# Application
ENV_STAGE=dev
SECRET_KEY=super-secret-key-change-me-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/swing_trade_db
# Local DB for dev: postgresql://postgres:postgres@localhost:5432/swing_trade_db

# Broker (m.Stock)
MSTOCK_API_KEY=your_api_key_here
MSTOCK_API_SECRET=your_api_secret_here
MSTOCK_CLIENT_ID=your_client_id_here


# Discord Webhooks
DISCORD_WEBHOOK_EARLY_RADAR=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_ENTRY_TRIGGER=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_EXITS=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_ERRORS=https://discord.com/api/webhooks/...
